# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/data_integrity_platform
MONGO_DB_NAME=data_integrity_platform

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000
FLASK_SECRET_KEY=your-secret-key-here

# JWT
JWT_SECRET_KEY=your-jwt-secret-here

# CORS Settings (Frontend URLs allowed)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Google OAuth (optional, for Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Email OTP (Gmail SMTP)
# Enable 2FA on Gmail → myaccount.google.com → Security → App passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# SMS OTP (Twilio) — leave blank to use console fallback (development)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OTP Settings
OTP_EMAIL_EXPIRY_MINUTES=10
OTP_PHONE_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=3
ACCOUNT_LOCKOUT_HOURS=24
MAX_DAILY_FAILURES=5
